# ============================================================
# Sysdig Monitor
# ============================================================
# Region URL (no trailing slash, no /api suffix)
#   US East  (us2): https://us2.app.sysdig.com
#   US West  (us1): https://app.sysdig.com
#   EU       (eu1): https://eu1.app.sysdig.com
#   AP/AU    (au1): https://app.au1.sysdig.com
SYSDIG_MONITOR_URL=https://us2.app.sysdig.com

# Sysdig **Monitor** API Token (NOT Secure token).
#   Settings -> Sysdig Monitor API -> API Token
SYSDIG_API_TOKEN=replace_me

# ============================================================
# GenAI providers (set the ones you use)
# ============================================================
OPENAI_API_KEY=sk-replace_me
# ANTHROPIC_API_KEY=sk-ant-replace_me

# ============================================================
# OTel Collector
# ============================================================
OTEL_LOG_LEVEL=info
